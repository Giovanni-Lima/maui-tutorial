<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GatelockVanLite.Views.Components.InputField"
			 x:Name="root">

    <VerticalStackLayout Spacing="2">

        <Border Style="{StaticResource TextInput}">
            <Entry 
                Placeholder="{Binding Placeholder, Source={x:Reference root}}"
                Keyboard="{Binding Keyboard, Source={x:Reference root}}"
                Text="{Binding Text, Source={x:Reference root}}"
                TextColor="Black"
                BackgroundColor="Transparent"
                HeightRequest="40"/>
        </Border>

        <Label 
            Text="{Binding ErrorText, Source={x:Reference root}}"
            TextColor="Red"
            FontSize="13"
            HorizontalOptions="End"
            IsVisible="{Binding ShowError, Source={x:Reference root}}"
            FontAttributes="Bold"/>

    </VerticalStackLayout>

</ContentView>