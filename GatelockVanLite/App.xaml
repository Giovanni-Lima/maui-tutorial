<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GatelockVanLite"
             x:Class="GatelockVanLite.App">
    <Application.Resources>
        <ResourceDictionary>
            <Style TargetType="Label" x:Key="BlueLabel">
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="TextColor" Value="#019ee3" />
            </Style>

            <Style TargetType="Label" x:Key="BlackLabel">
                <Setter Property="FontFamily" Value="OpenSansRegular" />
                <Setter Property="TextColor" Value="#1e1a19" />
            </Style>

            <Style x:Key="TitleLabel" BasedOn="{StaticResource BlueLabel}" TargetType="Label">
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="HorizontalOptions" Value="Center"/>
            </Style>

            <Style x:Key="InfoLabel" BasedOn="{StaticResource BlackLabel}" TargetType="Label">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="HorizontalTextAlignment" Value="Center"/>
                <Setter Property="LineBreakMode" Value="WordWrap"/>
            </Style>

            <Style x:Key="ButtonOutline" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="TextColor" Value="#FFFFFF"/>
                <Setter Property="BorderColor" Value="#FFFFFF"/>
                <Setter Property="BorderWidth" Value="2"/>
                <Setter Property="HeightRequest" Value="40"/>
                <Setter Property="CornerRadius" Value="10"/>
            </Style>

            <Style x:Key="CardView" TargetType="Border">
                <Setter Property="Stroke" Value="#DDDDDD" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="{StaticResource LightBackground}" />
            </Style>
            
            <Style x:Key="TextInput" TargetType="Border">
                <Setter Property="Stroke" Value="#DDDDDD" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
                <Setter Property="Padding" Value="10, 0, 10, 0" />
                <Setter Property="Background" Value="{StaticResource LightBackground}" />
            </Style>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
