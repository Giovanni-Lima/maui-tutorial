<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MonkeyFinder.DetailsPage"
             xmlns:viewmodel="clr-namespace:MonkeyFinder.ViewModel"
             x:DataType="viewmodel:MonkeyDetailsViewModel"
             Title="{Binding Monkey.Name}">

    <VerticalStackLayout>
        <Grid ColumnDefinitions="*,Auto,*"
              RowDefinitions="160,Auto,80">

            <BoxView BackgroundColor="{StaticResource Primary}"
                     Grid.ColumnSpan="3"
                     HeightRequest="160"
                     HorizontalOptions="Fill" />

            <Border 
                Grid.Row="0"
                Grid.ColumnSpan="3"
                HeightRequest="160"
                WidthRequest="160"
                HorizontalOptions="Center"
                VerticalOptions="Start"
                StrokeShape="RoundRectangle 80"
                StrokeThickness="5"
                Stroke="{StaticResource LightBackground}"
                Margin="0,80,0,80">

                <Image Source="{Binding Monkey.Image}"
                       HeightRequest="150"
                       WidthRequest="150"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

            </Border>

        </Grid>

        <Button Text="Show On Map"
                Command="{Binding ShowMonkeyOnMapCommand}"
                HorizontalOptions="Center"
                WidthRequest="200"
                Margin="10"
                Style="{StaticResource ButtonOutline}"/>

        <VerticalStackLayout Padding="10" Spacing="10">
            <Label Text="{Binding Monkey.Details}"
                   Style="{StaticResource MediumLabel}"/>
            <Label Text="{Binding Monkey.Location, StringFormat='Location: {0}'}"
                   Style="{StaticResource SmallLabel}" />
            <Label Text="{Binding Monkey.Population, StringFormat='Population: {0}'}"
                   Style="{StaticResource SmallLabel}"/>
        </VerticalStackLayout>
    </VerticalStackLayout>
    
</ContentPage>